{
  "name": "Love Story Builder",
  "short_name": "Love Story",
  "description": "Create and share your personalized love story with cinematic animations and beautiful designs",
  "start_url": "/index.html",
  "display": "standalone",
  "background_color": "#0a0e27",
  "theme_color": "#c084fc",
  "orientation": "portrait-primary",
  "icons": [
    {
      "src": "/assets/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/assets/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/assets/icons/icon-maskable.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/assets/images/screenshot-540.png",
      "sizes": "540x720",
      "type": "image/png"
    },
    {
      "src": "/assets/images/screenshot-1080.png",
      "sizes": "1080x1440",
      "type": "image/png"
    }
  ],
  "categories": ["lifestyle", "productivity"],
  "shortcuts": [
    {
      "name": "Create Story",
      "short_name": "Create",
      "description": "Start creating a new love story",
      "url": "/admin.html",
      "icons": [{
        "src": "/assets/icons/create-icon.png",
        "sizes": "96x96"
      }]
    },
    {
      "name": "View Gallery",
      "short_name": "Gallery",
      "description": "Browse your photo gallery",
      "url": "/gallery.html",
      "icons": [{
        "src": "/assets/icons/gallery-icon.png",
        "sizes": "96x96"
      }]
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [{
        "name": "media",
        "accept": ["image/*", "audio/*", "video/*"]
      }]
    }
  }
}